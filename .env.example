# Kimi / Moonshot API
KIMI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Mainland endpoint: https://api.moonshot.cn/v1
# International:     https://api.moonshot.ai/v1
KIMI_BASE_URL=https://api.moonshot.cn/v1
# Vision-capable models (verified April 2026):
#   kimi-k2.5                            (recommended, supports video too)
#   moonshot-v1-8k-vision-preview
#   moonshot-v1-32k-vision-preview
#   moonshot-v1-128k-vision-preview
KIMI_VISION_MODEL=kimi-k2.5
KIMI_TEXT_MODEL=moonshot-v1-8k

# wechatbot-sdk (iLink protocol via ilinkai.weixin.qq.com)
# On first run the SDK prints a QR URL — scan with WeChat on your phone to log in.
# Credentials persist at WECHATBOT_CRED_PATH.
WECHATBOT_CRED_PATH=./data/wechatbot_credentials.json

# App
DATABASE_PATH=./data/whatd_you_have.db
TIMEZONE=Asia/Shanghai
DAILY_SUMMARY_HOUR=21
DAILY_SUMMARY_MINUTE=0

# Nagging
NAG_AFTER_HOURS=5
NAG_INTERVAL_MINUTES=45
NAG_START_HOUR=8
NAG_END_HOUR=23

DEFAULT_DAILY_CALORIE_GOAL=1800
